{
  "name": "bigronjones-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "tsx backend/dev-server.ts",
    "start": "tsx backend/server.ts",
    "build": "vite build --config frontend/vite.config.ts && node scripts/generate-sitemap.mjs",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.app.json",
    "preview": "vite preview --config frontend/vite.config.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.88",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.3.1",
    "@supabase/supabase-js": "^2.104.1",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "isomorphic-dompurify": "^3.10.0",
    "lucide-react": "^0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "three": "^0.184.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "@vercel/node": "^5.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.7"
  }
}
